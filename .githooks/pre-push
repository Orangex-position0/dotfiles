#!/bin/bash

# ==================================================
# 安全 pre-push hook
# 功能：
# - 阻止 push 覆盖远程新提交
# - 不修改本地历史
# - 支持多分支 push
# ==================================================

REMOTE="$1"
REMOTE_URL="$2"

status=0

while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA
do
    # 跳过非 branch push
    if [[ ! "$LOCAL_REF" =~ ^refs/heads/ ]]; then
        continue
    fi

    BRANCH="${LOCAL_REF#refs/heads/}"

    echo "🔍 Checking $REMOTE/$BRANCH ..."

    # 首次推送（远程不存在）
    if [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
        echo "✅ New branch push"
        continue
    fi

    # 本地与远程一致
    if [ "$LOCAL_SHA" = "$REMOTE_SHA" ]; then
        echo "✅ Up to date"
        continue
    fi

    BASE=$(git merge-base "$LOCAL_SHA" "$REMOTE_SHA")

    # 本地落后远程
    if [ "$BASE" = "$LOCAL_SHA" ]; then
        echo "====================================================="
        echo "❌ Remote branch has new commits:"
        echo "   $REMOTE/$BRANCH"
        echo
        echo "💡 Please run:"
        echo "   git pull --rebase $REMOTE $BRANCH"
        echo "====================================================="
        status=1
    fi
done

exit $status
